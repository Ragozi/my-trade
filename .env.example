# =============================================================================
# My-Trade — Environment Configuration
# Copy to .env and fill in secrets. NEVER commit .env to git.
# =============================================================================

# --- Alpaca API (paper keys from https://app.alpaca.markets) ---
APCA_API_KEY_ID=your_paper_api_key
APCA_API_SECRET_KEY=your_paper_secret_key
PAPER_TRADING=true
ALLOW_LIVE_TRADING=false

# =============================================================================
# Asset class — Phase 4 (Claude research) requires equities
# =============================================================================
# Recommended for Phase 4 activation:
ASSET_CLASS=equities
CRYPTO_MODE=false
EQUITY_SYMBOLS=AAPL,MSFT,NVDA,AMD,TSLA

# Legacy crypto scalper (Phase 1–3 only; Claude skipped when equities_only=true):
# ASSET_CLASS=crypto
# CRYPTO_MODE=true
# CRYPTO_SYMBOLS=BTC/USD
# NOTIONAL_PER_TRADE=12.0

# --- Runtime ---
SCAN_INTERVAL_SECONDS=60
VERBOSE_DEBUG=false
LOG_EVERY_N_SCANS=5
SLACK_NOTIFY_SCANS=false
ENTRY_TIMEFRAME=1Min
TREND_TIMEFRAME=5Min
TREND_TIMEFRAME_15M=15Min
BAR_LIMIT=200

# --- Strategy (equities pullback defaults; loosen for more signals) ---
REQUIRE_5M_UPTREND=false
REQUIRE_15M_UPTREND=true
REQUIRE_VOLUME_SPIKE=false
REQUIRE_ABOVE_EMA9=false
REQUIRE_RSI_TURNING_UP=true
REQUIRE_MACD_POSITIVE=true
REQUIRE_MACD_EXPANDING=true
BOLLINGER_LOWER_HALF_ONLY=true
RSI_OVERSOLD=42
RSI_OVERBOUGHT=68
VWAP_PULLBACK_PCT=0.012
STOP_LOSS_PCT=0.0065
TAKE_PROFIT_PCT=0.017
MAX_HOLD_MINUTES=15

# --- Risk (SCOPE.md R1–R4) ---
MAX_RISK_PER_TRADE_PCT=0.02
MAX_TOTAL_OPEN_RISK_PCT=0.07
DAILY_LOSS_LIMIT_PCT=0.05
MAX_DRAWDOWN_PCT=0.15
MAX_OPEN_POSITIONS=1
MAX_ENTRIES_PER_SYMBOL_PER_DAY=10

# --- Optional screener (equities) ---
USE_SCREENER=false
SCREENER_TOP_N=5
SCREENER_REFRESH_SECONDS=900
SCREENER_TIMEFRAME=15Min
SCREENER_USE_MOVERS=false
SCREENER_MOVERS_SOURCE=actives
SCREENER_MOVERS_TOP=20

# =============================================================================
# Phase 4 — Claude research layer (ADVISORY ONLY)
# See docs/PHASE4_ACTIVATION.md for full guide.
# =============================================================================
# Master switch — false = zero Claude calls, deterministic-only (safe default)
ENABLE_CLAUDE=false

# Required when ENABLE_CLAUDE=true
ANTHROPIC_API_KEY=

# Advisory mode (recommended to start): Claude proposes, strategy + risk decide entries
CLAUDE_REQUIRE_APPROVAL=false

# Claude runs on equities only by default (skipped on crypto)
CLAUDE_EQUITIES_ONLY=true
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_IDEAS=5
CLAUDE_MIN_CONFIDENCE=0.55
CLAUDE_CALL_INTERVAL_SECONDS=1800
CLAUDE_MAX_CALLS_PER_DAY=8
CLAUDE_MARKET_HOURS_ONLY=true
CLAUDE_MAX_TOKENS=2048
CLAUDE_BILLING_COOLDOWN_SECONDS=3600

# Learning / evaluation persistence
CLAUDE_MEMORY_FILE=logs/research_memory.json
CLAUDE_MEMORY_MAX_REFLECTIONS=100
CLAUDE_PERFORMANCE_WINDOW=20
CLAUDE_EVALUATION_FILE=logs/research_evaluation.json
CLAUDE_EVALUATION_MAX_RECORDS=500

# Optional: one LLM post-mortem per day on closed trades (uses extra API call)
CLAUDE_POSTMORTEM_ENABLED=false
CLAUDE_POSTMORTEM_MAX_PER_DAY=1

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL=my-trade
