# =============================================================================
# My-Trade — Environment Configuration
# Copy to .env and fill in secrets. NEVER commit .env to git.
# =============================================================================

# --- Alpaca API (paper keys from https://app.alpaca.markets) ---
APCA_API_KEY_ID=your_paper_api_key
APCA_API_SECRET_KEY=your_paper_secret_key
PAPER_TRADING=true
ALLOW_LIVE_TRADING=false

# =============================================================================
# Asset class — Phase 4 (Claude research) requires equities
# =============================================================================
ASSET_CLASS=equities
CRYPTO_MODE=false
# Static fallback only when screener disabled or empty (movers-only uses no fallback)
EQUITY_SYMBOLS=

# --- Runtime ---
SCAN_INTERVAL_SECONDS=60
VERBOSE_DEBUG=false
LOG_EVERY_N_SCANS=5
SLACK_NOTIFY_SCANS=false
ENTRY_TIMEFRAME=1Min
TREND_TIMEFRAME=5Min
TREND_TIMEFRAME_15M=15Min
BAR_LIMIT=200

# --- Strategy: AM small-cap momentum day trades ($2–$20 wild movers) ---
REQUIRE_5M_UPTREND=false
REQUIRE_15M_UPTREND=false
REQUIRE_VOLUME_SPIKE=true
REQUIRE_ABOVE_EMA9=false
REQUIRE_RSI_TURNING_UP=false
REQUIRE_MACD_POSITIVE=true
REQUIRE_MACD_EXPANDING=false
BOLLINGER_LOWER_HALF_ONLY=false
MOMENTUM_ABOVE_VWAP=true
RSI_OVERSOLD=55
RSI_OVERBOUGHT=72
VWAP_PULLBACK_PCT=0.03
STOP_LOSS_PCT=0.01
TAKE_PROFIT_PCT=0.025
MAX_HOLD_MINUTES=90

# --- Risk — 1% daily growth target on $15k virtual ($150/day goal) ---
MAX_RISK_PER_TRADE_PCT=0.02
MAX_TOTAL_OPEN_RISK_PCT=0.05
DAILY_LOSS_LIMIT_PCT=0.01
DAILY_PROFIT_TARGET_PCT=0.01
MAX_DRAWDOWN_PCT=0.15
MAX_OPEN_POSITIONS=1
MAX_ENTRIES_PER_SYMBOL_PER_DAY=1
MAX_DAILY_ENTRIES=2
TRADING_CAPITAL=15000
MAX_NOTIONAL_PCT=0.45

# --- Screener: Alpaca gainers $2–$20, AM refresh, no mega-cap fallback ---
USE_SCREENER=true
SCREENER_MOVERS_ONLY=true
SCREENER_USE_MOVERS=true
SCREENER_MOVERS_SOURCE=gainers
SCREENER_MOVERS_TOP=40
SCREENER_MOVERS_MIN_VOLUME=50000
SCREENER_MERGE_SEED_WITH_MOVERS=false
SCREENER_SEED_SYMBOLS=
SCREENER_FALLBACK_TO_STATIC=false
SCREENER_EXCLUDE_LEVERAGED_ETFS=true
SCREENER_EXCLUDE_LARGE_CAPS=true
SCREENER_TOP_N=5
SCREENER_REFRESH_SECONDS=300
SCREENER_AM_REFRESH_SECONDS=60
SCREENER_TIMEFRAME=5Min
SCREENER_MIN_BARS=8
SCREENER_MIN_PRICE=2
SCREENER_MAX_PRICE=20
SCREENER_MIN_DOLLAR_VOLUME=100000
SCREENER_MIN_ATR_PCT=0.008
SCREENER_MIN_CHANGE_PCT=0.015
SCREENER_WEIGHT_VOLATILITY=1.5
SCREENER_WEIGHT_LIQUIDITY=0.8
SCREENER_WEIGHT_MOMENTUM=2.0

# =============================================================================
# Phase 4 / 4.5 — Multi-provider research (ADVISORY ONLY)
# =============================================================================
ENABLE_RESEARCH=true
RESEARCH_TIER_MODE=both

RESEARCH_WORKHORSE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
RESEARCH_WORKHORSE_INTERVAL_SECONDS=300
RESEARCH_WORKHORSE_MAX_CALLS_PER_DAY=24
RESEARCH_WORKHORSE_MAX_TOKENS=2048

RESEARCH_PREMIUM_PROVIDER=xai
RESEARCH_PREMIUM_XAI_MODEL=grok-4.3
RESEARCH_PREMIUM_OPENAI_MODEL=gpt-4o
RESEARCH_PREMIUM_INTERVAL_SECONDS=900
RESEARCH_PREMIUM_MAX_CALLS_PER_DAY=8
RESEARCH_PREMIUM_MAX_TOKENS=2048

XAI_API_KEY=
XAI_MODEL=grok-4.3

ENABLE_CLAUDE=true
ANTHROPIC_API_KEY=

CLAUDE_REQUIRE_APPROVAL=true
RESEARCH_BLOCK_AVOID=true
RESEARCH_BLOCK_HOLD=false
RESEARCH_ENTRY_VETO_MIN_CONFIDENCE=0.10
CLAUDE_EQUITIES_ONLY=true
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_IDEAS=8
CLAUDE_MIN_CONFIDENCE=0.55
CLAUDE_CALL_INTERVAL_SECONDS=900
CLAUDE_MAX_CALLS_PER_DAY=12
CLAUDE_MARKET_HOURS_ONLY=true
CLAUDE_MAX_TOKENS=2048
CLAUDE_BILLING_COOLDOWN_SECONDS=3600

RESEARCH_BRIEF_FILE=logs/research_brief.json
CLAUDE_MEMORY_FILE=logs/research_memory.json
CLAUDE_MEMORY_MAX_REFLECTIONS=100
TRADE_KNOWLEDGE_FILE=logs/trade_knowledge.json
TRADE_KNOWLEDGE_MAX_RECORDS=10000
CLAUDE_PERFORMANCE_WINDOW=20
CLAUDE_EVALUATION_FILE=logs/research_evaluation.json
CLAUDE_EVALUATION_MAX_RECORDS=500

CLAUDE_POSTMORTEM_ENABLED=true
CLAUDE_POSTMORTEM_MAX_PER_DAY=3

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL=my-trade
