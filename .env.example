# =============================================================================
# My-Trade — Environment Configuration
# Copy to .env and fill in secrets. NEVER commit .env to git.
# =============================================================================

# --- Alpaca API (paper keys from https://app.alpaca.markets) ---
APCA_API_KEY_ID=your_paper_api_key
APCA_API_SECRET_KEY=your_paper_secret_key
PAPER_TRADING=true
ALLOW_LIVE_TRADING=false

# =============================================================================
# Asset class — Phase 4 (Claude research) requires equities
# =============================================================================
# Recommended for Phase 4 activation:
ASSET_CLASS=equities
CRYPTO_MODE=false
EQUITY_SYMBOLS=AAPL,MSFT,NVDA,AMD,TSLA

# Legacy crypto scalper (Phase 1–3 only; Claude skipped when equities_only=true):
# ASSET_CLASS=crypto
# CRYPTO_MODE=true
# CRYPTO_SYMBOLS=BTC/USD
# NOTIONAL_PER_TRADE=12.0

# --- Runtime ---
SCAN_INTERVAL_SECONDS=60
VERBOSE_DEBUG=false
LOG_EVERY_N_SCANS=5
SLACK_NOTIFY_SCANS=false
ENTRY_TIMEFRAME=1Min
TREND_TIMEFRAME=5Min
TREND_TIMEFRAME_15M=15Min
BAR_LIMIT=200

# --- Strategy (equities pullback defaults; loosen for more signals) ---
REQUIRE_5M_UPTREND=false
REQUIRE_15M_UPTREND=true
REQUIRE_VOLUME_SPIKE=false
REQUIRE_ABOVE_EMA9=false
REQUIRE_RSI_TURNING_UP=true
REQUIRE_MACD_POSITIVE=true
REQUIRE_MACD_EXPANDING=true
BOLLINGER_LOWER_HALF_ONLY=true
RSI_OVERSOLD=42
RSI_OVERBOUGHT=68
VWAP_PULLBACK_PCT=0.012
STOP_LOSS_PCT=0.0065
TAKE_PROFIT_PCT=0.017
MAX_HOLD_MINUTES=15

# --- Risk — slow & steady small account ($15k virtual) ---
# Fewer trades, smaller bites, halt bad days early. Percentages use TRADING_CAPITAL.
# At $15k: ~$150/trade risk | ~$3k max position | ~$450 daily halt | 1 position max
MAX_RISK_PER_TRADE_PCT=0.01
MAX_TOTAL_OPEN_RISK_PCT=0.05
DAILY_LOSS_LIMIT_PCT=0.03
MAX_DRAWDOWN_PCT=0.15
MAX_OPEN_POSITIONS=1
MAX_ENTRIES_PER_SYMBOL_PER_DAY=1
TRADING_CAPITAL=15000
MAX_NOTIONAL_PCT=0.20

# --- Optional screener (equities) ---
USE_SCREENER=false
SCREENER_TOP_N=5
SCREENER_REFRESH_SECONDS=900
SCREENER_TIMEFRAME=15Min
SCREENER_USE_MOVERS=false
SCREENER_MOVERS_SOURCE=actives
SCREENER_MOVERS_TOP=20

# =============================================================================
# Phase 4 / 4.5 — Multi-provider research (ADVISORY ONLY)
# See docs/MULTI_PROVIDER_RESEARCH.md and docs/PHASE4_ACTIVATION.md
# =============================================================================

# Master switch — true when any tier below is configured with keys
ENABLE_RESEARCH=true

# Tier routing: both | workhorse_only | claude_only
RESEARCH_TIER_MODE=both

# --- Workhorse tier (cheap/frequent) — OpenAI or xAI Grok ---
# Get key: https://platform.openai.com/api-keys (NOT ChatGPT Plus)
RESEARCH_WORKHORSE_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
RESEARCH_WORKHORSE_INTERVAL_SECONDS=900
RESEARCH_WORKHORSE_MAX_CALLS_PER_DAY=16
RESEARCH_WORKHORSE_MAX_TOKENS=2048

# Premium fallback when ENABLE_CLAUDE=false — xAI Grok or OpenAI gpt-4o (sparse)
RESEARCH_PREMIUM_PROVIDER=xai
RESEARCH_PREMIUM_XAI_MODEL=grok-4.3
RESEARCH_PREMIUM_OPENAI_MODEL=gpt-4o
RESEARCH_PREMIUM_INTERVAL_SECONDS=1800
RESEARCH_PREMIUM_MAX_CALLS_PER_DAY=4
RESEARCH_PREMIUM_MAX_TOKENS=2048

XAI_API_KEY=
XAI_MODEL=grok-4.3

# --- Premium tier — Claude (sparse; disables RESEARCH_PREMIUM_* when true) ---
ENABLE_CLAUDE=false
ANTHROPIC_API_KEY=

# Advisory mode: strategy + risk still control all orders
CLAUDE_REQUIRE_APPROVAL=false
# Block deterministic entries when research says avoid/hold (independent of approval mode)
RESEARCH_BLOCK_AVOID=true
RESEARCH_BLOCK_HOLD=true
CLAUDE_EQUITIES_ONLY=true
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_IDEAS=5
CLAUDE_MIN_CONFIDENCE=0.55
CLAUDE_CALL_INTERVAL_SECONDS=1800
CLAUDE_MAX_CALLS_PER_DAY=6
CLAUDE_MARKET_HOURS_ONLY=true
CLAUDE_MAX_TOKENS=2048
CLAUDE_BILLING_COOLDOWN_SECONDS=3600

# Pre-digested journal brief (built by: poe research-brief)
RESEARCH_BRIEF_FILE=logs/research_brief.json

# Learning / evaluation persistence
CLAUDE_MEMORY_FILE=logs/research_memory.json
CLAUDE_MEMORY_MAX_REFLECTIONS=100
TRADE_KNOWLEDGE_FILE=logs/trade_knowledge.json
TRADE_KNOWLEDGE_MAX_RECORDS=10000
CLAUDE_PERFORMANCE_WINDOW=20
CLAUDE_EVALUATION_FILE=logs/research_evaluation.json
CLAUDE_EVALUATION_MAX_RECORDS=500

# Optional: LLM post-mortem on closed trades (uses premium or workhorse client)
CLAUDE_POSTMORTEM_ENABLED=true
CLAUDE_POSTMORTEM_MAX_PER_DAY=3
CLAUDE_POSTMORTEM_MAX_PER_DAY=1

# --- Instant off (deterministic-only trading) ---
# ENABLE_RESEARCH=false
# ENABLE_CLAUDE=false
# RESEARCH_WORKHORSE_PROVIDER=none

# --- Slack (optional) ---
SLACK_BOT_TOKEN=
SLACK_CHANNEL=my-trade
